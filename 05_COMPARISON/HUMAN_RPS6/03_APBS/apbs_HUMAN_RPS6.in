read
    mol pqr ../02_PQR/AF_P62753_HUMAN_RPS6.pqr
end

elec
    mg-manual

    dime 161 161 161

    glen 80 80 80

    gcent -7.052 5.551 9.050

    mol 1

    lpbe

    bcfl sdh

    pdie 2.0
    sdie 78.54

    srfm smol
    chgm spl2

    sdens 10.0
    srad 1.4
    swin 0.3

    temp 298.15

    ion charge 1 conc 0.15 radius 2.0
    ion charge -1 conc 0.15 radius 2.0

    calcenergy total
    calcforce no

    write pot dx HUMAN_RPS6_0.15M
end

quit
